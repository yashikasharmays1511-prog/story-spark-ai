{
  "name": "story-spark-ai",
  "private": true,
  "version": "1.0.0",
  "description": "Story Spark AI",
  "license": "MIT",
  "contributors": [
    {
      "name": "Charan Balaji",
      "email": "neelamapallicharanbalaji14@gmail.com",
      "url": "https://github.com/charanbalaji2005"
    }
  ],
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npx concurrently -n backend,frontend -c blue,green \"npm run dev -w story-spark-ai-backend\" \"npm run dev -w story-spark-ai-frontend\"",
    "dev:backend": "npm run dev -w story-spark-ai-backend",
    "dev:frontend": "npm run dev -w story-spark-ai-frontend",
    "build": "npm run build -w story-spark-ai-backend && npm run build -w story-spark-ai-frontend",
    "build:backend": "npm run build -w story-spark-ai-backend",
    "build:frontend": "npm run build -w story-spark-ai-frontend",
    "start:backend": "npm run start -w story-spark-ai-backend",
    "start:frontend": "npm run start -w story-spark-ai-frontend",
    "lint": "npm run lint -w story-spark-ai-frontend"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/cookie-parser": "^1.4.10",
    "concurrently": "^9.1.2"
  },
  "overrides": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.17.33"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3"
  }
}
