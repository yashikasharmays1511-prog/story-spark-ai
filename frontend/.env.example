# Backend API base URL (must include /api/v1)
VITE_BASE_URL=http://localhost:5000/api/v1

# Optional: Socket.IO server for live notifications (defaults to hosted service if unset)
VITE_SOCKET_URL=http://localhost:5000

# Google OAuth Client ID (get from Google Cloud Console)
# Contributors: Add your own Google OAuth Client ID here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com