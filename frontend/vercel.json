{
  "rewrites": [
    {
      "source": "/post/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Twitterbot|LinkedInBot|WhatsApp|Slackbot|Discordbot|facebookexternalhit).*"
        }
      ],
      "destination": "https://your-backend-url.com/api/post/meta/:id"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}